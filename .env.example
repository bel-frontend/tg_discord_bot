# --- Web / editor ---
# API server port for `bun run start`. `bun run dev` will choose a free backend
# port automatically and proxy the frontend to it.
PORT=3000
# Host port used by docker-compose; container still listens on PORT above.
DOCKER_HOST_PORT=3007
# Optional upper bound for the API server's automatic port fallback scan.
PORT_MAX=3050
# Optional preferred frontend port for `bun run dev`.
FRONTEND_PORT=3000
# Optional frontend proxy target when running the Next dev server separately.
# `bun run dev` sets API_PROXY_TARGET automatically.
# API_PROXY_TARGET=http://localhost:3000
# BACKEND_URL=http://localhost:3000
# Sign JWT sessions. Use a long random value in every non-local environment.
JWT_SECRET=please-change-this-to-a-long-random-string

# --- MongoDB ---
# Preferred: keep only the password secret in .env; the app builds:
# mongodb://${MONGODB_USER}:${MONGODB_PASSWORD}@${MONGODB_HOST}:${MONGODB_PORT}/${MONGODB_DB}?authSource=${MONGODB_AUTH_SOURCE}&replicaSet=${MONGODB_REPLICA_SET}
MONGODB_PASSWORD=your-mongodb-password
MONGODB_HOST=db.example.internal
MONGODB_PORT=27017
MONGODB_USER=your-mongodb-user
MONGODB_DB=your-database-name
MONGODB_AUTH_SOURCE=admin
MONGODB_REPLICA_SET=your-replica-set
# Optional: override the generated URI completely.
# MONGODB_URI=mongodb://user:password@db.example.internal:27017/app?authSource=admin&replicaSet=rs0

# --- Email (Resend) ---
# Used for invite emails (multi-user workspaces) and registration email verification.
# https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Composer <onboarding@resend.dev>
# Public origin used to build invite/verification links, e.g. https://composer.example.com
# Use http://localhost:3007 when running through the included docker-compose.yml.
PUBLIC_BASE_URL=http://localhost:3000

# --- Scheduler ---
# How often the background worker checks for due scheduled publications.
SCHEDULER_INTERVAL_MS=30000

# --- Telegram / Discord credentials ---
# Telegram and Discord credentials are stored per workspace from Settings in the
# app UI. Keep real bot tokens out of .env unless code is changed to pass env
# values into `new TelegramPlatform(...)` / `new DiscordPlatform(...)` in index.ts.
#
# Channel targets are stored in MongoDB and managed from Resources. Legacy envs
# such as TELEGRAM_CHANNEL_USERNAMES and DISCORD_CHANNEL_IDS are not read by the
# current app.

# --- Threads official API ---
# App credentials and per-workspace OAuth tokens are configured in Settings.
# These overrides are mainly useful for tests or non-standard Meta endpoints.
# THREADS_GRAPH_BASE_URL=https://graph.threads.net/v1.0
# THREADS_OAUTH_AUTHORIZE_URL=https://threads.net/oauth/authorize

# --- X browser session ---
# X publishes by driving a real logged-in browser session and stores that login
# session encrypted in MongoDB.
#
# Required while X is registered in index.ts. Generate with:
# openssl rand -base64 32
BROWSER_SESSION_ENC_KEY=please-generate-a-base64-32-byte-key

# Caps concurrent Chromium processes. Each browser can use roughly 150-300 MB
# resident memory, so size container memory limits with this in mind.
MAX_CONCURRENT_BROWSER_SESSIONS=3
# How long a live Connect browser waits for the user to finish logging in.
BROWSER_LOGIN_TIMEOUT_MS=600000
# Poll interval used while checking whether the browser login has completed.
BROWSER_LOGIN_POLL_MS=1000
# How long an idle automation browser context stays warm between operations.
BROWSER_IDLE_CLOSE_MS=300000
# Minimum delay between publish/delete operations for the same account+platform.
BROWSER_PLATFORM_OPERATION_COOLDOWN_MS=15000
# Force headless browser mode, useful for CI/server environments. On servers
# without an X server (no Xvfb) set this to true — publishing works headless;
# do the interactive login from your own machine with scripts/connect-local.ts.
BROWSER_HEADLESS=false
# Optional when using playwright-core without a bundled browser, especially on macOS.
# CHROME_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# X automation tuning. Increase these if the X UI is slow or publish confirmation
# is flaky in your environment.
X_ACTION_DELAY_MS=1200
X_POST_CONFIRM_TIMEOUT_MS=45000

# --- Client-side login (scripts/connect-local.ts) ---
# Logs in to X with a Chrome on YOUR machine and uploads the session to
# the server, for deploys that can't run a headed browser. Run:
#   bun scripts/connect-local.ts x
# COMPOSER_SERVER_URL=https://composer.example.com
# COMPOSER_TOKEN=            # JWT from the web app; or use email/password below
# COMPOSER_EMAIL=
# COMPOSER_PASSWORD=         # prompted on stdin when unset
# CONNECT_LOGIN_TIMEOUT_MS=600000

# --- Local browser smoke-test scripts only ---
# Used by scripts/test-x-connection.ts and scripts/test-x-post.ts.
X_STORAGE_STATE=/tmp/composer-x-storage-state.json
X_LOGIN_TIMEOUT_MS=120000
X_TEST_RESET=false
# X_TEST_POST_TEXT="temporary test post"
