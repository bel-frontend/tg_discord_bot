# --- Web / editor ---
PORT=3000
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=tg_discord_bot
JWT_SECRET=please-change-this-to-a-long-random-string

# --- Platform tokens ---
DISCORD_BOT_TOKEN=your-discord-bot-token
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# --- Channels shown in the picker ---
# Comma-separated. Each entry is a bare id/username, or "id|Friendly name".
# Telegram: @public_channel, or a numeric chat id (e.g. -1001234567890 / 553518183).
TELEGRAM_CHANNEL_USERNAMES="@my_channel|News (TG), 553518183|Team chat"
# Discord: channel ids.
DISCORD_CHANNEL_IDS="1374368491771002970|announcements"

# Optional: Discord guild (server) id — also pulls the server's text channels into the
# picker live (with their real #names), merged with DISCORD_CHANNEL_IDS above.
# DISCORD_GUILD_ID=123456789012345678

# Optional: extra channels from a JSON file (defaults to ./channels.json)
# CHANNELS_CONFIG_PATH=./channels.json
