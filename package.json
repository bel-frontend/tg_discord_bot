{
  "name": "tg_discord_bot",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "start": "bun run build && bun run index.ts",
    "dev": "bun run scripts/dev.ts",
    "build": "cd frontend && bun install && bun run build",
    "desktop:dev": "bun run scripts/desktop-dev.ts",
    "desktop:dist": "cd desktop && bun run dist",
    "test": "bun test src/*.test.ts src/platforms/*/*.test.ts && bun test desktop/test desktop/src/platforms/*/*.test.ts && cd frontend && bun run test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node-telegram-bot-api": "^0.64.8"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@atproto/api": "^0.20.30",
    "discord.js": "^14.19.3",
    "jose": "^6.2.3",
    "marked": "^18.0.5",
    "mongodb": "^6.9.0",
    "node-html-markdown": "^1.3.0",
    "node-telegram-bot-api": "^0.66.0",
    "resend": "^6.16.0"
  },
  "overrides": {
    "bson": "6.7.0"
  }
}
