{
    "name": "composer-desktop",
    "version": "0.1.0",
    "description": "Desktop Composer client and local publisher for Threads and X",
    "author": "Composer",
    "private": true,
    "main": "dist/main.js",
    "scripts": {
        "build": "bun build src/main.ts src/preload.ts --outdir dist --target node --format cjs --external electron",
        "dev": "bun run build && electron .",
        "dist": "bun run build && electron-builder"
    },
    "devDependencies": {
        "electron": "^37.2.0",
        "electron-builder": "^26.0.12"
    },
    "build": {
        "appId": "by.composer.desktop",
        "productName": "Composer",
        "files": [
            "dist/**/*",
            "src/setup.html",
            "package.json"
        ],
        "directories": {
            "output": "release"
        },
        "mac": {
            "target": ["dmg", "zip"],
            "category": "public.app-category.social-networking"
        },
        "win": {
            "target": ["nsis"]
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        }
    }
}
